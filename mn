  <search id="base_now">
    <query>| rest /services/search/jobs splunk_server=local
| search label="exclusion_bulk_risk_check"
| head 1
| eval current_week=strftime(now(), "%G-W%V"),
       last_refreshed=published
| fields current_week, last_refreshed</query>
    <earliest>-1m</earliest>
    <latest>now</latest>
  </search>


    <panel>
      <title>Data Last Refreshed</title>
      <single>
        <search base="base_now">
          <query>| table last_refreshed</query>
        </search>
        <option name="drilldown">none</option>
        <option name="height">60</option>
      </single>
    </panel>
